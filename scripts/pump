WITH log_lines AS (
    SELECT text
    FROM TABLE(
        rdsadmin.rds_file_util.read_text_file(
            'DATA_PUMP_DIR',
            'imp_ndg_metadata.dmp.log'
        )
    )
),
missing AS (
    SELECT DISTINCT
        REGEXP_SUBSTR(
            text,
            '''([^'']+)''',
            1,
            1,
            NULL,
            1
        ) AS tablespace_name
    FROM log_lines
    WHERE text LIKE '%ORA-00959%'
)
SELECT
    'CREATE TABLESPACE ' || tablespace_name ||
    ' DATAFILE SIZE 100M AUTOEXTEND ON NEXT 100M MAXSIZE UNLIMITED;'
AS create_stmt
FROM missing
WHERE tablespace_name IS NOT NULL
ORDER BY tablespace_name;
