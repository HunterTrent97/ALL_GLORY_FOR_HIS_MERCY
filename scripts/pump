WITH log_lines AS (
  SELECT text
  FROM TABLE(
    rdsadmin.rds_file_util.read_text_file(
      'DATA_PUMP_DIR',
      'imp_ndg_metadata_remap.log'
    )
  )
)
SELECT DISTINCT
  'CREATE ROLE "' ||
  REGEXP_SUBSTR(text, '''([^'']+)''', 1, 1, NULL, 1) ||
  '";' AS create_stmt
FROM log_lines
WHERE text LIKE '%ORA-01924:%role%';






WITH log_lines AS (
  SELECT text
  FROM TABLE(
    rdsadmin.rds_file_util.read_text_file(
      'DATA_PUMP_DIR',
      'imp_ndg_metadata_remap.log'
    )
  )
)
SELECT DISTINCT text
FROM log_lines
WHERE text LIKE '%Object type USER%failed%';
